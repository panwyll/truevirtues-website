# Copy to .env.local for local dev, or set these in Vercel → Project → Settings
# → Environment Variables. Everything works without them; they just enable
# optional features.

# --- Lead emails (free trial form) ---
# Get a free key at resend.com. Without it, leads appear in Vercel function logs.
RESEND_API_KEY=
LEAD_TO_EMAIL=truevirtuesjiujitsu@gmail.com
# Must be a verified sender on your Resend domain once you set RESEND_API_KEY.
LEAD_FROM_EMAIL=onboarding@resend.dev
# Each booker is added to a Resend Audience so a Resend Automation can send
# the follow-up. By default the code auto-finds/creates an audience called
# "New Leads" — no config needed. Override the name here if you want, or pin a
# specific audience by ID.
RESEND_AUDIENCE_NAME=New Leads
RESEND_AUDIENCE_ID=

# --- Paid trial (Stripe) ---
# Leave STRIPE_SECRET_KEY blank to keep the paid trial disabled (free trial only).
# Get keys at dashboard.stripe.com/apikeys (use a test key sk_test_… first).
STRIPE_SECRET_KEY=
# Show the "Reserve a paid trial" button. Set to "true" only once Stripe is configured.
NEXT_PUBLIC_PAID_TRIAL_ENABLED=false
# Either point to a Stripe Price…
STRIPE_PRICE_ID=
# …or omit STRIPE_PRICE_ID and set the amount here, in pence (1000 = £10).
PAID_TRIAL_AMOUNT=1000

# --- Martialytics booking widget (Option B) ---
# When both are set, the Martialytics widget replaces the built-in form as the
# booking path. Get these from your Martialytics account → Widgets page.
NEXT_PUBLIC_MARTIALYTICS_SCHOOL=
NEXT_PUBLIC_MARTIALYTICS_HASH=

# (Per-plan "Join now" One Touch Sign Up links live in lib/site.ts pricing.)

# Martialytics school ID — every trial booking is forwarded to Martialytics as
# a lead (from the leads widget). Defaults to TVJJ's ID in code; set to "" here
# to turn the forwarding off.
MARTIALYTICS_SCHOOL_ID=03f505c2-a968ab45-b050c125-60c6c2b8

# --- Google Analytics 4 ---
# Measurement ID from GA4 → Admin → Data streams → your web stream (G-XXXXXXXXXX).
# Leave blank to disable analytics entirely (no tracking, no cookies).
NEXT_PUBLIC_GA_ID=

# --- Site URL (used for Stripe redirects when Origin header is absent) ---
NEXT_PUBLIC_SITE_URL=https://www.truevirtuesjiujitsu.com
